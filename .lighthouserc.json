{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": ["http://localhost:3000"],
      "settings": {
        "chromeFlags": "--headless --no-sandbox --disable-gpu --disable-dev-shm-usage"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended"
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
